{
  "name": "nextjs-archive-microservices-app",
  "version": "0.1.0",
  "private": true,
  "description": "A Next.js and Express microservices starter for a heritage archive platform.",
  "type": "module",
  "workspaces": [
    "frontend",
    "api-gateway",
    "services/*",
    "shared"
  ],
  "scripts": {
    "dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build",
    "dev:docker": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build",
    "dev:watch": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --watch --build",
    "prod:docker": "docker compose up --build",
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:gateway": "npm --workspace api-gateway run dev",
    "build": "npm --workspaces --if-present run build",
    "lint": "npm --workspaces --if-present run lint",
    "test": "npm --workspaces --if-present run test"
  },
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
  "@swc/helpers": "0.5.15"
}
}
